# Copy this file to .env and fill in your values
# NEVER commit the actual .env file to GitHub

# Get your free API key from: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Optional: grounded live web search providers
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: choose groq, openai, or gemini for Analyst Chat + Executive Summary
ANSWER_PROVIDER=gemini

# Optional: choose openai, gemini, or duckduckgo
LIVE_SEARCH_PROVIDER=openai

# Optional: override live search models
OPENAI_WEB_SEARCH_MODEL=gpt-4.1-mini
GEMINI_WEB_SEARCH_MODEL=gemini-2.5-flash
