# .streamlit/secrets.toml.example
# Copy the values below into Streamlit Cloud → App Settings → Secrets
# DO NOT commit the real secrets.toml file — only this example

GROQ_API_KEY = "gsk_..."
GEMINI_API_KEY = "AIza..."
GEMINI_WEB_API_KEY = "AIza..."     # second Gemini account for live search
OPENAI_API_KEY = "sk-..."          # optional

ANSWER_PROVIDER = "gemini"
LIVE_SEARCH_PROVIDER = "gemini"
GEMINI_WEB_SEARCH_MODEL = "gemini-2.5-flash"
OPENAI_WEB_SEARCH_MODEL = "gpt-4.1-mini"

# Optional: Upstash Redis (for async processing on cloud)
# REDIS_HOST = "xxx.upstash.io"
# REDIS_PORT = "6379"
# REDIS_PASSWORD = "..."
